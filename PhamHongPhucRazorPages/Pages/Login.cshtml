@page
@model PhamHongPhucRazorPages.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - FUNews Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site-custom.css" asp-append-version="true" />
</head>
<body class="login-bg">
    <main class="card login-card">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="display-6 fw-bold">FUNews</div>
                <p class="text-muted mb-0">Management System</p>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }
            <form method="post">
                <div class="mb-3">
                    <label class="form-label" asp-for="Email"></label>
                    <input class="form-control form-control-lg" asp-for="Email" />
                    <span class="text-danger" asp-validation-for="Email"></span>
                </div>
                <div class="mb-4">
                    <label class="form-label" asp-for="Password"></label>
                    <input class="form-control form-control-lg" asp-for="Password" type="password" />
                    <span class="text-danger" asp-validation-for="Password"></span>
                </div>
                <button class="btn btn-primary btn-lg w-100"><i class="bi bi-box-arrow-in-right"></i> Login</button>
                <a class="btn btn-link w-100 mt-2" asp-page="/Index">Back to public news</a>
            </form>
        </div>
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
