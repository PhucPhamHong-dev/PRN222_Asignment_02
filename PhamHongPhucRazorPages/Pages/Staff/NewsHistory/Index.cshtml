@page
@model PhamHongPhucRazorPages.Pages.Staff.NewsHistory.IndexModel
@{
    ViewData["Title"] = "My News History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">My News History</h1>
        <p class="text-muted mb-0">Articles created by your staff account.</p>
    </div>
    <form class="d-flex gap-2" method="get">
        <input class="form-control" asp-for="Search" placeholder="Search my articles" />
        <button class="btn btn-outline-primary"><i class="bi bi-search"></i></button>
    </form>
</div>

<div class="card soft-card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead><tr><th>Title</th><th>Category</th><th>Status</th><th>Created</th><th>Modified</th></tr></thead>
                <tbody>
                @foreach (var article in Model.Articles)
                {
                    <tr>
                        <td><div class="fw-semibold">@article.NewsTitle</div><div class="small text-muted">@article.Headline</div></td>
                        <td>@article.Category?.CategoryName</td>
                        <td><span class="badge @(article.NewsStatus ? "text-bg-success" : "text-bg-secondary")">@(article.NewsStatus ? "Active" : "Inactive")</span></td>
                        <td>@article.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@article.ModifiedDate?.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
