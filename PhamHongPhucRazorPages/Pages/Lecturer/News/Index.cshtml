@page
@model PhamHongPhucRazorPages.Pages.Lecturer.News.IndexModel
@{
    ViewData["Title"] = "Lecturer News";
}

<div class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
        <div>
            <h1 class="page-title">Lecturer News</h1>
            <p class="text-muted mb-0">Active articles available to lecturer accounts.</p>
        </div>
        <form class="d-flex gap-2" method="get">
            <input class="form-control" asp-for="Search" placeholder="Search active news..." />
            <button class="btn btn-primary"><i class="bi bi-search"></i></button>
        </form>
    </div>
    <div class="row g-4">
        @foreach (var article in Model.Articles)
        {
            <div class="col-md-6 col-xl-4">
                <article class="card news-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge text-bg-success">@article.Category?.CategoryName</span>
                            <span class="small text-muted">@article.CreatedDate.ToString("dd/MM/yyyy")</span>
                        </div>
                        <h5>@article.NewsTitle</h5>
                        <p class="text-muted">@article.Headline</p>
                        <p>@article.NewsContent</p>
                        <div class="small text-muted"><i class="bi bi-person"></i> @article.CreatedBy?.AccountName</div>
                    </div>
                </article>
            </div>
        }
    </div>
</div>
