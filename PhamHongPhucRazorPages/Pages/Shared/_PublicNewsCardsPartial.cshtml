@model IReadOnlyList<BusinessObjects.Models.NewsArticle>

<div class="row g-4">
    @foreach (var article in Model)
    {
        <div class="col-md-6 col-xl-4">
            <article class="card news-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge text-bg-success">@article.Category?.CategoryName</span>
                        <span class="small text-muted">@article.CreatedDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <h5 class="card-title">@article.NewsTitle</h5>
                    <p class="text-muted">@article.Headline</p>
                    <p>@article.NewsContent</p>
                    <div class="small text-muted">
                        <i class="bi bi-person"></i> @article.CreatedBy?.AccountName
                    </div>
                </div>
            </article>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="alert alert-light border text-center">No active news articles found.</div>
        </div>
    }
</div>
