<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FUNews Management</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-custom.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PhamHongPhucRazorPages.styles.css" asp-append-version="true" />
</head>
<body>
@{
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var name = User.Identity?.Name;
    var isDashboard = role is "Admin" or "Staff";
}
<div class="app-shell">
    @if (isDashboard)
    {
        <aside class="sidebar">
            <a class="brand" asp-page="/Index"><i class="bi bi-newspaper"></i> FUNews</a>
            @if (role == "Admin")
            {
                <a asp-page="/Admin/Accounts/Index"><i class="bi bi-people"></i> Accounts</a>
                <a asp-page="/Admin/Reports/Index"><i class="bi bi-bar-chart"></i> Reports</a>
            }
            @if (role == "Staff")
            {
                <a asp-page="/Staff/Categories/Index"><i class="bi bi-folder"></i> Categories</a>
                <a asp-page="/Staff/NewsArticles/Index"><i class="bi bi-file-earmark-text"></i> News Articles</a>
                <a asp-page="/Staff/NewsHistory/Index"><i class="bi bi-clock-history"></i> My History</a>
                <a asp-page="/Staff/Profile/Index"><i class="bi bi-person"></i> Profile</a>
            }
        </aside>
    }
    <div class="app-main">
        <header>
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
                <div class="container-fluid px-4">
                    <a class="navbar-brand d-lg-none" asp-page="/Index">FUNews</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div id="mainNavbar" class="collapse navbar-collapse">
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item"><a class="nav-link" asp-page="/Index">Public News</a></li>
                            @if (role == "Lecturer")
                            {
                                <li class="nav-item"><a class="nav-link" asp-page="/Lecturer/News/Index">Lecturer News</a></li>
                            }
                        </ul>
                        <div class="d-flex align-items-center gap-3">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <span class="small text-muted">@name <span class="badge text-bg-primary">@role</span></span>
                                <a class="btn btn-outline-danger btn-sm" asp-page="/Logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
                            }
                            else
                            {
                                <a class="btn btn-primary btn-sm" asp-page="/Login"><i class="bi bi-box-arrow-in-right"></i> Login</a>
                            }
                        </div>
                    </div>
                </div>
            </nav>
        </header>
        <main role="main" class="content-wrap">
            @RenderBody()
        </main>
        <footer class="border-top footer text-muted px-4">
            <span>PRN222 Assignment 02 - Pham Hong Phuc - SE19B.NET - QE190133</span>
        </footer>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
